---
import { Picture } from 'astro:assets';
import Base from '../layouts/Base.astro';
import RecipeCard from '../components/RecipeCard.astro';
import heroImage from '../assets/food/hero-table.jpg';
import { recipes, recipesBySlug } from '../data/recipes';
import { weeklyPlan, weekRange } from '../data/plan';

const previewDays = weeklyPlan.slice(0, 3);
const featuredRecipes = recipes.slice(0, 3);
---

<Base title="Plate Notes" current="home" preloadImage={heroImage.src}>
  <section class="relative overflow-hidden bg-cream-100">
    <div class="mx-auto grid max-w-6xl items-center gap-12 px-6 py-16 md:grid-cols-[1.05fr_1fr] md:py-24">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sage-700">Weekly meal plans · {weekRange}</p>
        <h1 class="mt-4 text-4xl font-semibold leading-[1.05] tracking-tight text-ink md:text-5xl lg:text-6xl">
          Eat better this week —<br/>
          <span class="text-sage-700">without overthinking it.</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-ink-soft">
          Plate Notes builds an honest, six-day plan around recipes you'll actually cook. Real ingredients, real macros, and a shopping list that fits a normal Sunday.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/plan" class="rounded-full bg-sage-700 px-6 py-3 text-sm font-semibold text-cream-50 transition-colors hover:bg-sage-800">
            See this week's plan
          </a>
          <a href="/recipes" class="rounded-full border border-sage-300 bg-cream-50 px-6 py-3 text-sm font-semibold text-sage-800 transition-colors hover:border-sage-500 hover:bg-cream-100">
            Browse recipes
          </a>
        </div>
        <dl class="mt-10 max-w-md flex flex-wrap gap-x-6 gap-y-3 text-sm">
          <div class="flex items-baseline gap-2">
            <dt class="text-ink-muted">Days planned</dt>
            <dd class="text-base font-semibold text-ink tabular-nums">6</dd>
          </div>
          <span class="text-sage-300" aria-hidden="true">·</span>
          <div class="flex items-baseline gap-2">
            <dt class="text-ink-muted">Pantry list</dt>
            <dd class="text-base font-semibold text-ink">printable</dd>
          </div>
          <span class="text-sage-300" aria-hidden="true">·</span>
          <div class="flex items-baseline gap-2">
            <dt class="text-ink-muted">Leftovers</dt>
            <dd class="text-base font-semibold text-ink">built in</dd>
          </div>
          <span class="text-sage-300" aria-hidden="true">·</span>
          <div class="flex items-baseline gap-2">
            <dt class="text-ink-muted">No app</dt>
            <dd class="text-base font-semibold text-ink">just a page</dd>
          </div>
        </dl>
      </div>
      <div class="relative">
        <div class="overflow-hidden rounded-3xl shadow-[0_30px_60px_-30px_rgba(56,70,47,0.45)]">
          <Picture
            src={heroImage}
            alt="A wooden table set with bowls of grains, roasted vegetables, fresh herbs, and a glass of water."
            formats={['avif', 'webp']}
            widths={[560, 800, 1100]}
            sizes="(min-width: 768px) 45vw, 95vw"
            loading="eager"
            fetchpriority="high"
            class="h-full w-full object-cover"
          />
        </div>
        <div class="absolute -bottom-6 -left-6 hidden rounded-2xl border border-sage-100 bg-cream-50 px-5 py-4 shadow-lg md:block">
          <p class="text-xs uppercase tracking-wider text-sage-700">This week's calories</p>
          <p class="mt-1 text-2xl font-semibold text-ink">~1,920 / day</p>
          <p class="text-xs text-ink-muted">Balanced across 3 meals</p>
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 py-20">
    <div class="flex items-end justify-between gap-6">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sage-700">This week's plan</p>
        <h2 class="mt-2 text-3xl font-semibold tracking-tight text-ink md:text-4xl">A look at the first three days</h2>
      </div>
      <a href="/plan" class="hidden text-sm font-semibold text-sage-700 underline-offset-4 hover:underline sm:inline">
        See the full week →
      </a>
    </div>
    <div class="mt-10 grid gap-6 md:grid-cols-3">
      {previewDays.map((day) => (
        <article class="rounded-2xl border border-sage-100 bg-white p-6">
          <header class="flex items-baseline justify-between border-b border-sage-100 pb-4">
            <h3 class="text-lg font-semibold text-ink">{day.day}</h3>
            <span class="text-xs text-ink-muted">{day.date}</span>
          </header>
          <ul class="mt-4 space-y-3 text-sm">
            {(['breakfast', 'lunch', 'dinner'] as const).map((slot) => {
              const slug = day.meals[slot];
              const recipe = slug ? recipesBySlug.get(slug) : null;
              return (
                <li class="flex items-start gap-3">
                  <span class="mt-1 inline-block h-2 w-2 flex-none rounded-full bg-sage-400" aria-hidden="true"></span>
                  <div>
                    <p class="text-[11px] uppercase tracking-wider text-sage-700">{slot}</p>
                    {recipe ? (
                      <a href={`/recipes/${recipe.slug}`} class="text-ink hover:text-sage-700">{recipe.title}</a>
                    ) : (
                      <p class="text-ink-muted">—</p>
                    )}
                  </div>
                </li>
              );
            })}
          </ul>
        </article>
      ))}
    </div>
  </section>

  <section class="bg-cream-100">
    <div class="mx-auto max-w-6xl px-6 py-20">
      <div class="flex items-end justify-between gap-6">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sage-700">Recipe library</p>
          <h2 class="mt-2 text-3xl font-semibold tracking-tight text-ink md:text-4xl">A handful to start with</h2>
        </div>
        <a href="/recipes" class="hidden text-sm font-semibold text-sage-700 underline-offset-4 hover:underline sm:inline">
          See all {recipes.length} →
        </a>
      </div>
      <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredRecipes.map((recipe) => (
          <RecipeCard recipe={recipe} />
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-6 py-20 text-center">
    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sage-700">No app to download</p>
    <h2 class="mt-3 text-3xl font-semibold tracking-tight text-ink md:text-4xl">Open the page on Sunday. Cook through the week.</h2>
    <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-ink-soft">
      Plate Notes isn't another tracker. It's a published weekly plan you can read in five minutes — with a shopping list ready to go on the way to the store.
    </p>
    <a href="/shopping-list" class="mt-8 inline-flex rounded-full bg-sage-700 px-6 py-3 text-sm font-semibold text-cream-50 transition-colors hover:bg-sage-800">
      View this week's shopping list
    </a>
  </section>
</Base>
