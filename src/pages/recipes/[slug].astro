---
import { Picture } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { recipes } from '../../data/recipes';

export function getStaticPaths() {
  return recipes.map((recipe) => ({ params: { slug: recipe.slug }, props: { recipe } }));
}

const { recipe } = Astro.props;
const totalMinutes = recipe.prepMinutes + recipe.cookMinutes;
const slotLabel = recipe.slot.charAt(0).toUpperCase() + recipe.slot.slice(1);

const aisles = ['produce', 'protein', 'dairy', 'grains', 'pantry', 'frozen'] as const;
const grouped = aisles
  .map((aisle) => ({ aisle, items: recipe.ingredients.filter((i) => i.aisle === aisle) }))
  .filter((g) => g.items.length > 0);
---

<Base title={recipe.title} current="recipes" description={recipe.blurb} preloadImage={recipe.image.src}>
  <article>
    <section class="border-b border-sage-100 bg-cream-100">
      <div class="mx-auto grid max-w-6xl items-center gap-12 px-6 py-14 md:grid-cols-[1fr_1.05fr] md:py-20">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sage-700">{slotLabel} · {totalMinutes} minutes</p>
          <h1 class="mt-3 text-4xl font-semibold leading-tight tracking-tight text-ink md:text-5xl">{recipe.title}</h1>
          <p class="mt-5 max-w-xl text-lg leading-relaxed text-ink-soft">{recipe.blurb}</p>
          <dl class="mt-8 grid max-w-md grid-cols-4 gap-4 text-center text-sm">
            <div class="rounded-xl border border-sage-100 bg-cream-50 px-2 py-3">
              <dt class="text-[11px] uppercase tracking-wider text-ink-muted">Calories</dt>
              <dd class="mt-1 text-lg font-semibold text-ink">{recipe.macros.calories}</dd>
            </div>
            <div class="rounded-xl border border-sage-100 bg-cream-50 px-2 py-3">
              <dt class="text-[11px] uppercase tracking-wider text-ink-muted">Protein</dt>
              <dd class="mt-1 text-lg font-semibold text-ink">{recipe.macros.protein}g</dd>
            </div>
            <div class="rounded-xl border border-sage-100 bg-cream-50 px-2 py-3">
              <dt class="text-[11px] uppercase tracking-wider text-ink-muted">Carbs</dt>
              <dd class="mt-1 text-lg font-semibold text-ink">{recipe.macros.carbs}g</dd>
            </div>
            <div class="rounded-xl border border-sage-100 bg-cream-50 px-2 py-3">
              <dt class="text-[11px] uppercase tracking-wider text-ink-muted">Fat</dt>
              <dd class="mt-1 text-lg font-semibold text-ink">{recipe.macros.fat}g</dd>
            </div>
          </dl>
          <div class="mt-6 flex flex-wrap gap-2">
            {recipe.tags.map((tag) => (
              <span class="rounded-full border border-sage-200 bg-cream-50 px-3 py-1 text-xs font-medium text-sage-800">{tag}</span>
            ))}
          </div>
        </div>
        <div class="overflow-hidden rounded-3xl shadow-[0_30px_60px_-30px_rgba(56,70,47,0.45)]">
          <Picture
            src={recipe.image}
            alt={recipe.imageAlt}
            formats={['avif', 'webp']}
            widths={[560, 800, 1100]}
            sizes="(min-width: 768px) 45vw, 95vw"
            loading="eager"
            fetchpriority="high"
            class="h-full w-full object-cover"
          />
        </div>
      </div>
    </section>

    <section class="mx-auto grid max-w-6xl gap-12 px-6 py-16 md:grid-cols-[1fr_1.4fr]">
      <aside>
        <h2 class="text-xl font-semibold tracking-tight text-ink">Ingredients</h2>
        <p class="mt-1 text-sm text-ink-muted">Makes {recipe.servings} serving{recipe.servings === 1 ? '' : 's'}</p>
        <div class="mt-5 space-y-5">
          {grouped.map((g) => (
            <div>
              <h3 class="text-[11px] font-semibold uppercase tracking-wider text-sage-700">{g.aisle}</h3>
              <ul class="mt-2 divide-y divide-sage-100 border-y border-sage-100">
                {g.items.map((i) => (
                  <li class="flex items-baseline justify-between py-2 text-sm">
                    <span class="text-ink">{i.item}</span>
                    <span class="ml-3 whitespace-nowrap text-ink-muted">{i.qty}</span>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </aside>
      <div>
        <h2 class="text-xl font-semibold tracking-tight text-ink">Method</h2>
        <ol class="mt-5 space-y-5">
          {recipe.steps.map((step, idx) => (
            <li class="flex gap-4">
              <span class="flex h-8 w-8 flex-none items-center justify-center rounded-full bg-sage-700 text-sm font-semibold text-cream-50">{idx + 1}</span>
              <p class="pt-1 text-base leading-relaxed text-ink-soft">{step}</p>
            </li>
          ))}
        </ol>
        <div class="mt-12 rounded-2xl border border-sage-100 bg-cream-100 p-6">
          <p class="text-xs font-semibold uppercase tracking-wider text-sage-700">Up next</p>
          <p class="mt-2 text-ink-soft">
            Looking for the rest of the week? <a href="/plan" class="text-sage-700 underline decoration-sage-300 underline-offset-4 hover:text-sage-800">See the full meal plan →</a>
          </p>
        </div>
      </div>
    </section>
  </article>
</Base>
