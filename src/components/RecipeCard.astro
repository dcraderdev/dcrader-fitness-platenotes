---
import { Picture } from 'astro:assets';
import type { Recipe } from '../data/recipes';

interface Props {
  recipe: Recipe;
  /** Set to true for above-the-fold cards so the first image is eagerly loaded. */
  eager?: boolean;
}

const { recipe, eager = false } = Astro.props;
const totalMinutes = recipe.prepMinutes + recipe.cookMinutes;
const slotLabel = recipe.slot.charAt(0).toUpperCase() + recipe.slot.slice(1);
---

<a
  href={`/recipes/${recipe.slug}`}
  class="group flex h-full flex-col overflow-hidden rounded-2xl border border-sage-100 bg-white shadow-[0_1px_0_rgba(110,132,86,0.05)] transition-shadow hover:shadow-[0_8px_24px_-12px_rgba(56,70,47,0.25)]"
>
  <div class="aspect-[4/3] overflow-hidden bg-cream-100">
    <Picture
      src={recipe.image}
      alt={recipe.imageAlt}
      formats={['avif', 'webp']}
      widths={[400, 640, 900]}
      sizes="(min-width: 1024px) 30vw, (min-width: 640px) 45vw, 95vw"
      loading={eager ? 'eager' : 'lazy'}
      fetchpriority={eager ? 'high' : 'auto'}
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.02]"
    />
  </div>
  <div class="flex flex-1 flex-col gap-3 p-5">
    <div class="flex items-center gap-2 text-xs">
      <span class="rounded-full bg-sage-100 px-2.5 py-0.5 font-medium text-sage-800">{slotLabel}</span>
      <span class="text-ink-muted">{totalMinutes} min · {recipe.macros.calories} cal</span>
    </div>
    <h3 class="text-lg font-semibold leading-snug text-ink group-hover:text-sage-700">{recipe.title}</h3>
    <p class="text-sm leading-relaxed text-ink-muted">{recipe.blurb}</p>
  </div>
</a>
